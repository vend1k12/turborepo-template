# =================================================================
# General & Port Configuration
# =================================================================
PORT=4000

# =================================================================
# Database Configuration
# =================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vend1k

# Driver selection (packages/db): auto-detects by host — a *.neon.tech URL uses
# the Neon serverless driver (WebSocket/HTTP, works on Vercel functions); any
# other host uses node-postgres (for local Docker Postgres / CI). Force with:
# DB_DRIVER=neon   # or: pg
# In production on Vercel + Neon, set DATABASE_URL to the Neon POOLED connection
# string (the "-pooler" host) and the driver is picked automatically.

# =================================================================
# Authentication Configuration (Better Auth)
# =================================================================
BETTER_AUTH_SECRET=placeholder-secret-must-be-32-characters-long
BETTER_AUTH_URL=http://localhost:4000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:4000

# =================================================================
# API Client Configuration
# =================================================================
NEXT_PUBLIC_API_URL=http://localhost:4000

# =================================================================
# Cross-App URLs (used by the web landing page nav/CTAs)
# =================================================================
NEXT_PUBLIC_DOCS_URL=http://localhost:3001
NEXT_PUBLIC_USER_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_URL=http://localhost:3003

# =================================================================
# Build Configuration
# =================================================================
BUILD_STANDALONE=false

# =================================================================
# Error Tracking Configuration (Sentry)
# =================================================================
NEXT_PUBLIC_SENTRY_DISABLED=true
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# =================================================================
# PRODUCTION (Vercel + Neon) — reference values, set per project in the
# Vercel dashboard, NOT in this file. See DEPLOY.md for the full guide.
# =================================================================
# NODE_ENV is set to "production" by Vercel automatically. That flips the auth
# session cookie to sameSite=none + secure + partitioned so it works across the
# different *.vercel.app hosts (api vs. user vs. admin are separate sites).
#
# API project (apps/api):
#   DATABASE_URL=postgres://...neon.tech/...?sslmode=require   # Neon POOLED url
#   BETTER_AUTH_SECRET=<32+ char random secret>
#   BETTER_AUTH_URL=https://<your-api>.vercel.app
#   NEXT_PUBLIC_USER_URL=https://<your-user>.vercel.app
#   NEXT_PUBLIC_ADMIN_URL=https://<your-admin>.vercel.app
#
# Frontend projects (apps/user, apps/admin, apps/web):
#   NEXT_PUBLIC_API_URL=https://<your-api>.vercel.app
#   NEXT_PUBLIC_BETTER_AUTH_URL=https://<your-api>.vercel.app
#   NEXT_PUBLIC_DOCS_URL / NEXT_PUBLIC_USER_URL / NEXT_PUBLIC_ADMIN_URL=https://...
#
# Preview deploys: every PR gets a fresh random *.vercel.app hostname. Those are
# matched automatically — CORS via @vend1k/shared/origins, auth via the
# "https://*.vercel.app" entry in trustedOrigins. No per-PR config needed.
