{
  "name": "turbo-starter-next-hono",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "bun --env-file=.env turbo run build",
    "dev": "bun --env-file=.env turbo run dev",
    "dev:web": "bun --env-file=.env turbo run dev --filter=@vend1k/web",
    "dev:docs": "bun --env-file=.env turbo run dev --filter=@vend1k/docs",
    "dev:user": "bun --env-file=.env turbo run dev --filter=@vend1k/user",
    "dev:admin": "bun --env-file=.env turbo run dev --filter=@vend1k/admin",
    "dev:api": "bun --env-file=.env turbo run dev --filter=@vend1k/api",
    "dev:all": "bun --env-file=.env turbo run dev",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:drop": "bun run --cwd packages/db db:drop",
    "db:check": "bun run --cwd packages/db db:check",
    "check": "bun run --cwd packages/db db:check",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
