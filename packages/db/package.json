{
  "name": "@vend1k/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env drizzle-kit migrate",
    "db:push": "bun --env-file=../../.env drizzle-kit push",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio",
    "db:drop": "bun --env-file=../../.env drizzle-kit drop",
    "db:check": "bun --env-file=../../.env drizzle-kit check"
  },
  "devDependencies": {
    "@vend1k/typescript-config": "*",
    "typescript": "5.9.2",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.4"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.39.0",
    "pg": "^8.13.0"
  }
}
